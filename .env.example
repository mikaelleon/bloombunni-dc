# Required: Discord bot token (Developer Portal → Bot → Reset / copy token)
BOT_TOKEN=your_bot_token_here

# Optional: your Discord server ID — when set, slash commands register ONLY in this guild (fast updates,
# no duplicate /commands there). Global commands are cleared on Discord while this is set — other servers
# will not see slash commands until you remove this line and restart. Right‑click server → Copy Server ID.
# SYNC_GUILD_ID=123456789012345678

# Optional: one-time fix if you *removed* SYNC_GUILD_ID but still see duplicate slash commands — set to
# that same server ID, restart bot once, then remove this line. Clears stale guild-scoped commands.
# GUILD_SLASH_PURGE_ID=123456789012345678

# Everything else is configured per Discord server with /setup and /config (stored in bot.db).
# Do not put channel IDs, role IDs, or payment details here.
