# Required
BOT_TOKEN=your_bot_token_here

# Optional: set to your server ID for fast slash-command sync (omit for global sync)
GUILD_ID=0

# Payment copy (shown in payment buttons / panels)
GCASH_DETAILS=Name: Example | Number: 0000
PAYPAL_LINK=https://paypal.me/example
KOFI_LINK=https://ko-fi.com/example
GCASH_QR_URL=https://example.com/gcash.png
PAYPAL_QR_URL=https://example.com/paypal.png

# Channels and roles are configured in Discord with /serverconfig (no IDs here).
